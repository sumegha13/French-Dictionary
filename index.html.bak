<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>French Vocabulary List</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #fafafa;
            padding: 20px;
            color: #333;
        }

        h1 {
            text-align: center;
            color: #444;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-bottom: 15px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 8px;
            overflow: hidden;
        }

        th,
        td {
            padding: 12px;
            border-bottom: 1px solid #eee;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: #f2f2f2;
            font-weight: bold;
        }

        tr:hover {
            background: #f9f9f9;
        }

        button {
            padding: 6px 10px;
            border: none;
            background: #4CAF50;
            color: white;
            border-radius: 4px;
            cursor: pointer;
        }

        button:hover {
            background: #45a049;
        }
    </style>
</head>

<body>

    <h1>French Vocabulary List</h1>

    <input type="text" id="search" placeholder="Search French, English, pronunciation, or example..."
        onkeyup="filterTable()">

    <table id="vocabTable">
        <table>
            <thead>
                <tr>
                    <th>Word / Verb</th>
                    <th>Meaning</th>
                    <th>Pronunciation</th>
                    <th>Example / Conjugation</th>
                    <th>Audio</th>
                </tr>
            </thead>
            <tbody>
                <!-- POSSESSIVE ADJECTIVES -->
                <tr>
                    <td>mon</td>
                    <td>my (masc.)</td>
                    <td>mon</td>
                    <td>Mon ami est ici.</td>
                    <td><button onclick="speak('mon')">🔊</button></td>
                </tr>
                <tr>
                    <td>ma</td>
                    <td>my (fem.)</td>
                    <td>mah</td>
                    <td>Ma maison est grande.</td>
                    <td><button onclick="speak('ma')">🔊</button></td>
                </tr>
                <tr>
                    <td>mes</td>
                    <td>my (plural)</td>
                    <td>may</td>
                    <td>Mes clés sont perdues.</td>
                    <td><button onclick="speak('mes')">🔊</button></td>
                </tr>
                <tr>
                    <td>ton</td>
                    <td>your (masc.)</td>
                    <td>ton</td>
                    <td>Ton chien est mignon.</td>
                    <td><button onclick="speak('ton')">🔊</button></td>
                </tr>
                <tr>
                    <td>ta</td>
                    <td>your (fem.)</td>
                    <td>tah</td>
                    <td>Ta sœur est gentille.</td>
                    <td><button onclick="speak('ta')">🔊</button></td>
                </tr>
                <tr>
                    <td>tes</td>
                    <td>your (plural)</td>
                    <td>tay</td>
                    <td>Tes livres sont sur la table.</td>
                    <td><button onclick="speak('tes')">🔊</button></td>
                </tr>
                <tr>
                    <td>son</td>
                    <td>his/her (masc.)</td>
                    <td>son</td>
                    <td>Son fils a dix ans.</td>
                    <td><button onclick="speak('son')">🔊</button></td>
                </tr>
                <tr>
                    <td>sa</td>
                    <td>his/her (fem.)</td>
                    <td>sah</td>
                    <td>Sa fille est à l’école.</td>
                    <td><button onclick="speak('sa')">🔊</button></td>
                </tr>
                <tr>
                    <td>ses</td>
                    <td>his/her (plural)</td>
                    <td>say</td>
                    <td>Ses amis arrivent.</td>
                    <td><button onclick="speak('ses')">🔊</button></td>
                </tr>
                <tr>
                    <td>notre</td>
                    <td>our (sing.)</td>
                    <td>not-ruh</td>
                    <td>Notre maison est ici.</td>
                    <td><button onclick="speak('notre')">🔊</button></td>
                </tr>
                <tr>
                    <td>nos</td>
                    <td>our (plural)</td>
                    <td>noh</td>
                    <td>Nos enfants jouent.</td>
                    <td><button onclick="speak('nos')">🔊</button></td>
                </tr>
                <tr>
                    <td>votre</td>
                    <td>your (formal)</td>
                    <td>vot-ruh</td>
                    <td>Votre voiture est prête.</td>
                    <td><button onclick="speak('votre')">🔊</button></td>
                </tr>
                <tr>
                    <td>vos</td>
                    <td>your (plural)</td>
                    <td>voh</td>
                    <td>Vos clés sont là.</td>
                    <td><button onclick="speak('vos')">🔊</button></td>
                </tr>
                <tr>
                    <td>leur</td>
                    <td>their (sing.)</td>
                    <td>luhr</td>
                    <td>Leur chien dort.</td>
                    <td><button onclick="speak('leur')">🔊</button></td>
                </tr>
                <tr>
                    <td>leurs</td>
                    <td>their (plural)</td>
                    <td>luhr</td>
                    <td>Leurs amis sont gentils.</td>
                    <td><button onclick="speak('leurs')">🔊</button></td>
                </tr>

                <!-- NOUNS -->
                <tr>
                    <td>ami</td>
                    <td>friend (male)</td>
                    <td>ah-mee</td>
                    <td>Mon ami parle français.</td>
                    <td><button onclick="speak('ami')">🔊</button></td>
                </tr>
                <tr>
                    <td>amie</td>
                    <td>friend (female)</td>
                    <td>ah-mee</td>
                    <td>Mon amie est drôle.</td>
                    <td><button onclick="speak('amie')">🔊</button></td>
                </tr>
                <tr>
                    <td>soeur</td>
                    <td>sister</td>
                    <td>sir</td>
                    <td>Ma sœur est à la maison.</td>
                    <td><button onclick="speak('sœur')">🔊</button></td>
                </tr>
                <tr>
                    <td>fils</td>
                    <td>son</td>
                    <td>feess</td>
                    <td>Son fils joue dehors.</td>
                    <td><button onclick="speak('fils')">🔊</button></td>
                </tr>
                <tr>
                    <td>fille</td>
                    <td>daughter</td>
                    <td>fee</td>
                    <td>Sa fille lit un livre.</td>
                    <td><button onclick="speak('fille')">🔊</button></td>
                </tr>
                <tr>
                    <td>maison</td>
                    <td>home</td>
                    <td>meh-zon</td>
                    <td>Ma maison est petite.</td>
                    <td><button onclick="speak('maison')">🔊</button></td>
                </tr>
                <tr>
                    <td>livre</td>
                    <td>book</td>
                    <td>leev-ruh</td>
                    <td>Le livre est intéressant.</td>
                    <td><button onclick="speak('livre')">🔊</button></td>
                </tr>
                <tr>
                    <td>clés</td>
                    <td>keys</td>
                    <td>clay</td>
                    <td>Mes clés sont ici.</td>
                    <td><button onclick="speak('clés')">🔊</button></td>
                </tr>
                <tr>
                    <td>chien</td>
                    <td>dog</td>
                    <td>shee-en</td>
                    <td>Le chien mange.</td>
                    <td><button onclick="speak('chien')">🔊</button></td>
                </tr>
                <tr>
                    <td>boulangerie</td>
                    <td>bakery</td>
                    <td>boo-lahn-zhuh-ree</td>
                    <td>Je vais à la boulangerie.</td>
                    <td><button onclick="speak('boulangerie')">🔊</button></td>
                </tr>
                <tr>
                    <td>ville</td>
                    <td>city</td>
                    <td>veel</td>
                    <td>Lyon est une grande ville.</td>
                    <td><button onclick="speak('ville')">🔊</button></td>
                </tr>
                <tr>
                    <td>métro</td>
                    <td>metro</td>
                    <td>may-troh</td>
                    <td>Je prends le métro pour aller au travail.</td>
                    <td><button onclick="speak('métro')">🔊</button></td>
                </tr>
                <tr>
                    <td>magasin</td>
                    <td>shop / store</td>
                    <td>mah-gah-zan</td>
                    <td>Je vais au magasin.</td>
                    <td><button onclick="speak('magasin')">🔊</button></td>
                </tr>
                <tr>
                    <td>emploi</td>
                    <td>job</td>
                    <td>ahm-plwah</td>
                    <td>Je cherche un emploi.</td>
                    <td><button onclick="speak('emploi')">🔊</button></td>
                </tr>

                <!-- VERBS WITH PRESENT TENSE -->
                <tr>
                    <td>parler</td>
                    <td>to speak</td>
                    <td>par-lay</td>
                    <td>Je parle, Tu parles, Il/Elle parle, Nous parlons, Vous parlez, Ils/Elles parlent</td>
                    <td><button onclick="speak('parler')">🔊</button></td>
                </tr>
                <tr>
                    <td>venir</td>
                    <td>to come</td>
                    <td>vuh-neer</td>
                    <td>Je viens, Tu viens, Il/Elle vient, Nous venons, Vous venez, Ils/Elles viennent</td>
                    <td><button onclick="speak('venir')">🔊</button></td>
                </tr>
                <tr>
                    <td>conduire</td>
                    <td>to drive</td>
                    <td>kon-dweer</td>
                    <td>Je conduis, Tu conduis, Il/Elle conduit, Nous conduisons, Vous conduisez, Ils/Elles conduisent
                    </td>
                    <td><button onclick="speak('conduire')">🔊</button></td>
                </tr>
                <tr>
                    <td>nager</td>
                    <td>to swim</td>
                    <td>nah-zhay</td>
                    <td>Je nage, Tu nages, Il/Elle nage, Nous nageons, Vous nagez, Ils/Elles nagent</td>
                    <td><button onclick="speak('nager')">🔊</button></td>
                </tr>
                <tr>
                    <td>aider</td>
                    <td>to help</td>
                    <td>eh-day</td>
                    <td>J’aide, Tu aides, Il/Elle aide, Nous aidons, Vous aidez, Ils/Elles aident</td>
                    <td><button onclick="speak('aider')">🔊</button></td>
                </tr>
                <tr>
                    <td>commencer</td>
                    <td>to start</td>
                    <td>ko-mon-say</td>
                    <td>Je commence, Tu commences, Il/Elle commence, Nous commençons, Vous commencez, Ils/Elles
                        commencent</td>
                    <td><button onclick="speak('commencer')">🔊</button></td>
                </tr>
                <tr>
                    <td>jouer</td>
                    <td>to play</td>
                    <td>zhoo-ay</td>
                    <td>Je joue, Tu joues, Il/Elle joue, Nous jouons, Vous jouez, Ils/Elles jouent</td>
                    <td><button onclick="speak('jouer')">🔊</button></td>
                </tr>
                <tr>
                    <td>lire</td>
                    <td>to read</td>
                    <td>leer</td>
                    <td>Je lis, Tu lis, Il/Elle lit, Nous lisons, Vous lisez, Ils/Elles lisent</td>
                    <td><button onclick="speak('lire')">🔊</button></td>
                </tr>
                <tr>
                    <td>trouver</td>
                    <td>to find</td>
                    <td>troo-vay</td>
                    <td>Je trouve, Tu trouves, Il/Elle trouve, Nous trouvons, Vous trouvez, Ils/Elles trouvent</td>
                    <td><button onclick="speak('trouver')">🔊</button></td>
                </tr>
                <tr>
                    <td>étudier</td>
                    <td>to study</td>
                    <td>ay-too-dyay</td>
                    <td>J’étudie, Tu étudies, Il/Elle étudie, Nous étudions, Vous étudiez, Ils/Elles étudient</td>
                    <td><button onclick="speak('étudier')">🔊</button></td>
                </tr>
                <tr>
                    <td>travailler</td>
                    <td>to work</td>
                    <td>tra-vai-yay</td>
                    <td>Je travaille, Tu travailles, Il/Elle travaille, Nous travaillons, Vous travaillez, Ils/Elles
                        travaillent</td>
                    <td><button onclick="speak('travailler')">🔊</button></td>
                </tr>
                <tr>
                    <td>partir</td>
                    <td>to leave</td>
                    <td>par-teer</td>
                    <td>Je pars, Tu pars, Il/Elle part, Nous partons, Vous partez, Ils/Elles partent</td>
                    <td><button onclick="speak('partir')">🔊</button></td>
                </tr>
                <tr>
                    <td>appeler</td>
                    <td>to call</td>
                    <td>ap-lay</td>
                    <td>J’appelle, Tu appelles, Il/Elle appelle, Nous appelons, Vous appelez, Ils/Elles appellent</td>
                    <td><button onclick="speak('appeler')">🔊</button></td>
                </tr>
                <tr>
                    <td>nettoyer</td>
                    <td>to clean</td>
                    <td>neh-twa-yay</td>
                    <td>Je nettoie, Tu nettoies, Il/Elle nettoie, Nous nettoyons, Vous nettoyez, Ils/Elles nettoient
                    </td>
                    <td><button onclick="speak('nettoyer')">🔊</button></td>
                </tr>
                <tr>
                    <td>écouter</td>
                    <td>to listen</td>
                    <td>ay-koo-tay</td>
                    <td>J’écoute, Tu écoutes, Il/Elle écoute, Nous écoutons, Vous écoutez, Ils/Elles écoutent</td>
                    <td><button onclick="speak('écouter')">🔊</button></td>
                </tr>
                <tr>
                    <td>finir</td>
                    <td>to finish</td>
                    <td>fee-neer</td>
                    <td>Je finis, Tu finis, Il/Elle finit, Nous finissons, Vous finissez, Ils/Elles finissent</td>
                    <td><button onclick="speak('finir')">🔊</button></td>
                </tr>
                <tr>
                    <td>acheter</td>
                    <td>to buy</td>
                    <td>ash-tay</td>
                    <td>J’achète, Tu achètes, Il/Elle achète, Nous achetons, Vous achetez, Ils/Elles achètent</td>
                    <td><button onclick="speak('acheter')">🔊</button></td>
                </tr>
                <tr>
                    <td>dormir</td>
                    <td>to sleep</td>
                    <td>dor-meer</td>
                    <td>Je dors, Tu dors, Il/Elle dort, Nous dormons, Vous dormez, Ils/Elles dorment</td>
                    <td><button onclick="speak('dormir')">🔊</button></td>
                </tr>
                <tr>
                    <td>faire attention</td>
                    <td>to be careful</td>
                    <td>fair ah-ton-syon</td>
                    <td>Je fais attention, Tu fais attention, Il/Elle fait attention, Nous faisons attention, Vous
                        faites attention, Ils/Elles font attention</td>
                    <td><button onclick="speak('faire attention')">🔊</button></td>
                </tr>

                <!-- EXPRESSIONS & USEFUL WORDS -->
                <tr>
                    <td>du</td>
                    <td>some / uncountable</td>
                    <td>dyu</td>
                    <td>Je bois du café.</td>
                    <td><button onclick="speak('du')">🔊</button></td>
                </tr>
                <tr>
                    <td>des</td>
                    <td>some (plural)</td>
                    <td>day</td>
                    <td>J’achète des fruits.</td>
                    <td><button onclick="speak('des')">🔊</button></td>
                </tr>
                <tr>
                    <td>de</td>
                    <td>of / from</td>
                    <td>duh</td>
                    <td>Je viens de l’Inde.</td>
                    <td><button onclick="speak('de')">🔊</button></td>
                </tr>
                <tr>
                    <td>dans</td>
                    <td>in / inside</td>
                    <td>dahn</td>
                    <td>Je suis dans la boulangerie.</td>
                    <td><button onclick="speak('dans')">🔊</button></td>
                </tr>
                <tr>
                    <td>à</td>
                    <td>at / in</td>
                    <td>a</td>
                    <td>J’habite à Lyon.</td>
                    <td><button onclick="speak('à')">🔊</button></td>
                </tr>
                <tr>
                    <td>en</td>
                    <td>in (countries)</td>
                    <td>ahn</td>
                    <td>Je vis en France.</td>
                    <td><button onclick="speak('en')">🔊</button></td>
                </tr>
                <tr>
                    <td>un peu</td>
                    <td>a little / some</td>
                    <td>uhn puh</td>
                    <td>Je parle un peu français.</td>
                    <td><button onclick="speak('un peu')">🔊</button></td>
                </tr>
                <tr>
                    <td>très</td>
                    <td>very</td>
                    <td>tray</td>
                    <td>C’est très récent.</td>
                    <td><button onclick="speak('très')">🔊</button></td>
                </tr>
                <tr>
                    <td>tous les jours</td>
                    <td>every day</td>
                    <td>too-lay-zhoor</td>
                    <td>Je pratique le français tous les jours.</td>
                    <td><button onclick="speak('tous les jours')">🔊</button></td>
                </tr>
                <tr>
                    <td>J’essaie</td>
                    <td>I try / I am trying</td>
                    <td>zhe-say</td>
                    <td>J’essaie d’apprendre le français.</td>
                    <td><button onclick="speak('J’essaie')">🔊</button></td>
                </tr>
                <tr>
                    <td>au revoir</td>
                    <td>goodbye</td>
                    <td>oh ruh-vwar</td>
                    <td>Au revoir et merci.</td>
                    <td><button onclick="speak('au revoir')">🔊</button></td>
                </tr>
                <tr>
                    <td>bonne journée</td>
                    <td>have a good day</td>
                    <td>bun zhor-nay</td>
                    <td>Bonne journée, madame.</td>
                    <td><button onclick="speak('bonne journée')">🔊</button></td>
                </tr>
                <tr>
                    <td>voici</td>
                    <td>here is</td>
                    <td>vwah-see</td>
                    <td>Voici votre reçu.</td>
                    <td><button onclick="speak('voici')">🔊</button></td>
                </tr>
                <tr>
                    <td>d’accord</td>
                    <td>okay</td>
                    <td>dah-kor</td>
                    <td>D’accord, merci.</td>
                    <td><button onclick="speak('d’accord')">🔊</button></td>
                </tr>
                <tr>
                    <td>souvent</td>
                    <td>often</td>
                    <td>soo-vohn</td>
                    <td>Je vais souvent à la boulangerie.</td>
                    <td><button onclick="speak('souvent')">🔊</button></td>
                </tr>
                <tr>
                    <td>A plus tard</td>
                    <td>see you later</td>
                    <td>ah ploo tar</td>
                    <td>A plus tard, mon ami !</td>
                    <td><button onclick="speak('A plus tard')">🔊</button></td>
                </tr>
                <tr>
                    <td>comme ci, comme ça</td>
                    <td>so-so / not bad</td>
                    <td>kom see, kom sa</td>
                    <td>Ça va comme ci, comme ça.</td>
                    <td><button onclick="speak('comme ci, comme ça')">🔊</button></td>
                </tr>
                <tr>
                    <td>oh là là</td>
                    <td>expression of surprise / wow</td>
                    <td>oh lah lah</td>
                    <td>Oh là là, c’est incroyable !</td>
                    <td><button onclick="speak('oh là là')">🔊</button></td>
                </tr>
                <tr>
                    <td>maintenant même</td>
                    <td>right now</td>
                    <td>man-ten-ah mem</td>
                    <td>Fais-le maintenant même.</td>
                    <td><button onclick="speak('maintenant même')">🔊</button></td>
                </tr>
                <tr>
                    <td>quelques</td>
                    <td>some / a few</td>
                    <td>kel-kuh</td>
                    <td>J’ai quelques amis ici.</td>
                    <td><button onclick="speak('quelques')">🔊</button></td>
                </tr>
                <tr>
                    <td>tout de suite</td>
                    <td>right away / immediately</td>
                    <td>too duh sweet</td>
                    <td>Fais-le tout de suite !</td>
                    <td><button onclick="speak('tout de suite')">🔊</button></td>
                </tr>
                <tr>
                    <td>peut-être</td>
                    <td>maybe</td>
                    <td>puh-tet</td>
                    <td>Peut-être que je viendrai.</td>
                    <td><button onclick="speak('peut-être')">🔊</button></td>
                </tr>

                <!-- DAY & FAMILY USEFUL WORDS -->
                <tr>
                    <td>pour</td>
                    <td>for / to</td>
                    <td>poor</td>
                    <td>C’est pour toi.</td>
                    <td><button onclick="speak('pour')">🔊</button></td>
                </tr>
                <tr>
                    <td>depuis</td>
                    <td>since / for (time)</td>
                    <td>duh-pwee</td>
                    <td>J’habite ici depuis deux ans.</td>
                    <td><button onclick="speak('depuis')">🔊</button></td>
                </tr>
                <tr>
                    <td>ensuite</td>
                    <td>then / next</td>
                    <td>ahn-sweet</td>
                    <td>Nous mangeons et ensuite nous sortons.</td>
                    <td><button onclick="speak('ensuite')">🔊</button></td>
                </tr>
                <tr>
                    <td>réveiller</td>
                    <td>to wake up</td>
                    <td>ray-vay-yay</td>
                    <td>Je me réveille à 7 heures.</td>
                    <td><button onclick="speak('réveiller')">🔊</button></td>
                </tr>
                <tr>
                    <td>salle de bain</td>
                    <td>bathroom</td>
                    <td>sal duh ban</td>
                    <td>La salle de bain est à gauche.</td>
                    <td><button onclick="speak('salle de bain')">🔊</button></td>
                </tr>
                <tr>
                    <td>brosse</td>
                    <td>brush</td>
                    <td>bross</td>
                    <td>J’ai besoin d’une brosse.</td>
                    <td><button onclick="speak('brosse')">🔊</button></td>
                </tr>
                <tr>
                    <td>dents</td>
                    <td>teeth</td>
                    <td>dahn</td>
                    <td>Je me brosse les dents.</td>
                    <td><button onclick="speak('dents')">🔊</button></td>
                </tr>
                <tr>
                    <td>je me</td>
                    <td>I myself (reflexive)</td>
                    <td>zhuh muh</td>
                    <td>Je me prépare.</td>
                    <td><button onclick="speak('je me')">🔊</button></td>
                </tr>
                <tr>
                    <td>petit-déjeuner</td>
                    <td>breakfast</td>
