                <tr></tr>
                <!-- DAILY UPDATE END -->
            </tbody>
        </table>

        <script>
            function filterTable() {
                const input = document.getElementById("search").value.toLowerCase();
                const rows = document.querySelectorAll("#vocabTable tbody tr");

                rows.forEach(row => {
                    const french = row.children[0].textContent.toLowerCase();
                    const english = row.children[1].textContent.toLowerCase();
                    const pron = row.children[2].textContent.toLowerCase();
                    const example = row.children[3].textContent.toLowerCase();

                    row.style.display =
                        french.includes(input) ||
                            english.includes(input) ||
                            pron.includes(input) ||
                            example.includes(input)
                            ? "" : "none";
                });
            }

            function speak(word) {
                const utter = new SpeechSynthesisUtterance(word);
                utter.lang = "fr-FR";
                speechSynthesis.speak(utter);
            }
        </script>

